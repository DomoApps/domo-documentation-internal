# Salesforce credentials for migrate_internal_docs.py
#
# SF_ACCESS_TOKEN — Salesforce access token or session ID (SID).
#   Option A (easiest): Copy the 'sid' cookie value from browser devtools while
#   logged into domo-support.domo.com → Application → Cookies → sid.
#   Option B: Use a Salesforce OAuth2 access token from a Connected App.
#
SF_ACCESS_TOKEN=

# Salesforce instance URL (default shown — change if your org URL differs)
SF_INSTANCE_URL=https://domo.my.salesforce.com

# Salesforce API version (default shown)
SF_API_VERSION=v59.0

# Knowledge article object name.
# Run: python scripts/migrate_internal_docs.py --describe Knowledge__kav
# to list all fields on this object. Change if the default doesn't match your org.
SF_KNOWLEDGE_OBJECT=Knowledge__kav

# Body field name on the Knowledge article object.
# Leave blank to auto-detect (tries Body, ArticleBody, Article_Body__c, ARTICLE_BODY__C).
# Set explicitly once auto-detect resolves it to speed up subsequent runs.
SF_BODY_FIELD=
